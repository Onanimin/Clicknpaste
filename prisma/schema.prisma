generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Paste {
  id         String   @id
  content    String   @db.Text
  createdAt  DateTime @default(now())
  expiresAt  DateTime?
  maxViews   Int?
  viewCount  Int      @default(0)
  passwordHash String?
}